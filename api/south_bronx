local GITHUB_RAW = "https://raw.githubusercontent.com/sadx8992-lgtm/jean14_17/main"
local KEYS_URL = GITHUB_RAW .. "/keys.json"

-- Variables
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")

local FlyActive = false
local FlySpeed = 50
local ESPActive = false
local ESPFolder = nil
local ScriptActive = false
local RagdollParts = {}

-- =====================
-- KEY VALIDATION SYSTEM
-- =====================

local function ValidateKey(key)
    local success, response = pcall(function()
        return game:HttpGet(KEYS_URL)
    end)
    
    if not success then
        print("[ERROR] No se pudo conectar al servidor de keys")
        return false
    end
    
    local keys_data = HttpService:JSONDecode(response)
    
    -- Verificar si la key está en available_keys
    for _, available_key in ipairs(keys_data.available_keys) do
        if available_key == key then
            -- Key válida, verificar si ya fue usada
            for _, used_key in ipairs(keys_data.used_keys) do
                if used_key == key then
                    print("[⚠️] Key Usada - Esta llave ya fue utilizada")
                    return false
                end
            end
            print("[✓] Key Válida - Acceso Concedido")
            ScriptActive = true
            return true
        end
    end
    
    print("[✗] Key Inválida")
    return false
end

-- =====================
-- RAGDOLL FLY SYSTEM (Cuerpo Caído)
-- =====================

local function CreateRagdoll()
    local character = LocalPlayer.Character
    if not character then return end
    
    -- Desactivar colisiones y físicas
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end
    
    -- Crear BodyVelocity para movimiento
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        local bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bodyVelocity.Parent = rootPart
        RagdollParts.bodyVelocity = bodyVelocity
        
        local bodyGyro = Instance.new("BodyGyro")
        bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bodyGyro.Parent = rootPart
        RagdollParts.bodyGyro = bodyGyro
    end
    
    -- Hacer ragdoll (cuerpo caído)
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Landed, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Running, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.RunningNoPhysics, false)
        humanoid.PlatformStand = true
    end
end

local function StartFly()
    if not ScriptActive then
        print("[!] Debes validar una key primero")
        return
    end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    FlyActive = true
    CreateRagdoll()
    
    local connection
    connection = game:GetService("RunService").RenderStepped:Connect(function()
        if not FlyActive or not LocalPlayer.Character then
            connection:Disconnect()
            -- Limpiar ragdoll
            if RagdollParts.bodyVelocity then
                RagdollParts.bodyVelocity:Destroy()
            end
            if RagdollParts.bodyGyro then
                RagdollParts.bodyGyro:Destroy()
            end
            local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid.PlatformStand = false
                humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
                humanoid:SetStateEnabled(Enum.HumanoidStateType.Landed, true)
                humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
                humanoid:SetStateEnabled(Enum.HumanoidStateType.Running, true)
                humanoid:SetStateEnabled(Enum.HumanoidStateType.RunningNoPhysics, true)
            end
            RagdollParts = {}
            return
        end
        
        local moveDirection = Vector3.new(0, 0, 0)
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            moveDirection = moveDirection + (Camera.CFrame.LookVector * Vector3.new(1, 0, 1)).Unit
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            moveDirection = moveDirection - (Camera.CFrame.LookVector * Vector3.new(1, 0, 1)).Unit
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            moveDirection = moveDirection - Camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            moveDirection = moveDirection + Camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            moveDirection = moveDirection + Vector3.new(0, 1, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
            moveDirection = moveDirection - Vector3.new(0, 1, 0)
        end
        
        if moveDirection.Magnitude > 0 then
            moveDirection = moveDirection.Unit
        end
        
        if RagdollParts.bodyVelocity then
            RagdollParts.bodyVelocity.Velocity = moveDirection * FlySpeed
        end
        if RagdollParts.bodyGyro then
            RagdollParts.bodyGyro.CFrame = Camera.CFrame
        end
    end)
    
    print("[✈️] Ragdoll Fly Activado - W/A/S/D para mover, Space/Ctrl para subir/bajar")
end

local function StopFly()
    FlyActive = false
    print("[✈️] Fly Desactivado")
end

-- =====================
-- ESP SYSTEM (Mejorado)
-- =====================

local function CreateESPGui(player)
    if player == LocalPlayer then return end
    if not player.Character then return end
    
    local character = player.Character
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end
    
    -- Crear carpeta para ESP si no existe
    if not ESPFolder then
        ESPFolder = Instance.new("Folder")
        ESPFolder.Name = "ESPFolder"
        ESPFolder.Parent = workspace
    end
    
    -- Crear BillboardGui
    local billboardGui = Instance.new("BillboardGui")
    billboardGui.Size = UDim2.new(4, 0, 2, 0)
    billboardGui.MaxDistance = 500
    billboardGui.Parent = humanoidRootPart
    
    -- Crear TextLabel
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.BackgroundTransparency = 0.5
    textLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    textLabel.TextSize = 18
    textLabel.Font = Enum.Font.GothamBold
    textLabel.Text = player.Name
    textLabel.Parent = billboardGui
    
    -- Crear Box (LineHandleAdornment para dibujar caja)
    local box = Instance.new("BoxHandleAdornment")
    box.Size = humanoidRootPart.Size + Vector3.new(0.5, 2, 0.5)
    box.Color3 = Color3.fromRGB(0, 255, 0)
    box.Transparency = 0.3
    box.Parent = humanoidRootPart
    
    return {gui = billboardGui, label = textLabel, box = box}
end

local ESPPlayers = {}

local function StartESP()
    if not ScriptActive then
        print("[!] Debes validar una key primero")
        return
    end
    
    ESPActive = true
    print("[👁️] ESP Activado")
    
    -- Crear ESP para jugadores existentes
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and not ESPPlayers[player] then
            ESPPlayers[player] = CreateESPGui(player)
        end
    end
    
    -- Crear ESP para nuevos jugadores
    local playerAddedConnection
    playerAddedConnection = Players.PlayerAdded:Connect(function(player)
        if ESPActive and player ~= LocalPlayer then
            wait(0.5)
            ESPPlayers[player] = CreateESPGui(player)
        end
    end)
    
    -- Actualizar ESP constantemente
    local espUpdateConnection
    espUpdateConnection = game:GetService("RunService").RenderStepped:Connect(function()
        if not ESPActive then
            espUpdateConnection:Disconnect()
            playerAddedConnection:Disconnect()
            return
        end
        
        for player, espData in pairs(ESPPlayers) do
            if player and player.Parent and player.Character then
                local character = player.Character
                local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
                local humanoid = character:FindFirstChild("Humanoid")
                
                if humanoidRootPart and humanoid then
                    -- Actualizar distancia
                    local distance = (LocalPlayer.Character.HumanoidRootPart.Position - humanoidRootPart.Position).Magnitude
                    local health = math.floor(humanoid.Health)
                    espData.label.Text = player.Name .. " [" .. math.floor(distance) .. "m] " .. health .. "HP"
                    
                    -- Cambiar color según salud
                    if health > 50 then
                        espData.label.TextColor3 = Color3.fromRGB(0, 255, 0)
                        espData.box.Color3 = Color3.fromRGB(0, 255, 0)
                    elseif health > 25 then
                        espData.label.TextColor3 = Color3.fromRGB(255, 255, 0)
                        espData.box.Color3 = Color3.fromRGB(255, 255, 0)
                    else
                        espData.label.TextColor3 = Color3.fromRGB(255, 0, 0)
                        espData.box.Color3 = Color3.fromRGB(255, 0, 0)
                    end
                else
                    -- Eliminar si el jugador está muerto
                    pcall(function()
                        espData.gui:Destroy()
                        espData.box:Destroy()
                    end)
                    ESPPlayers[player] = nil
                end
            else
                -- Eliminar si el jugador se fue
                pcall(function()
                    if espData then
                        espData.gui:Destroy()
                        espData.box:Destroy()
                    end
                end)
                ESPPlayers[player] = nil
            end
        end
    end)
    
    -- Limpiar cuando jugador se va
    Players.PlayerRemoving:Connect(function(player)
        if ESPPlayers[player] then
            pcall(function()
                ESPPlayers[player].gui:Destroy()
                ESPPlayers[player].box:Destroy()
            end)
            ESPPlayers[player] = nil
        end
    end)
end

local function StopESP()
    ESPActive = false
    for player, espData in pairs(ESPPlayers) do
        pcall(function()
            espData.gui:Destroy()
            espData.box:Destroy()
        end)
    end
    ESPPlayers = {}
    print("[👁️] ESP Desactivado")
end

-- =====================
-- INPUT SYSTEM
-- =====================

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.F then
        if FlyActive then
            StopFly()
        else
            StartFly()
        end
    elseif input.KeyCode == Enum.KeyCode.E then
        if ESPActive then
            StopESP()
        else
            StartESP()
        end
    end
end)

